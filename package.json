{
  "name": "vscode-working-cat",
  "displayName": "Working Cat for Claude Code",
  "description": "Monitor Claude Code sessions with an animated cat. Notifies you of AI status changes — thinking, complete, permission needed, or error.",
  "version": "1.2.0",
  "publisher": "qvtec3",
  "icon": "assets/cat.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/qvtec/vscode-working-cat"
  },
  "keywords": [
    "cat",
    "claude",
    "claude code",
    "ai",
    "activity",
    "notifier",
    "notification",
    "status",
    "fun"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "working-cat",
          "title": "Working Cat",
          "icon": "assets/cat.png"
        }
      ]
    },
    "commands": [
      {
        "command": "workingCat.unregisterHooks",
        "title": "Working Cat: Unregister Claude Code Hooks"
      }
    ],
    "configuration": {
      "title": "Working Cat",
      "properties": {
        "workingCat.background": {
          "type": "string",
          "enum": [
            "bg_park",
            "bg_park_evening",
            "bg_park_night",
            "bg_home",
            "bg_cyberpunk"
          ],
          "enumDescriptions": [
            "Park garden",
            "Park garden evening",
            "Park garden night",
            "Japanese house",
            "Cyberpunk city"
          ],
          "default": "bg_park",
          "description": "Background scene"
        },
        "workingCat.sound": {
          "type": "boolean",
          "default": true,
          "description": "Play cat sounds"
        },
        "workingCat.volume": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Cat sound volume (0.0 - 1.0)"
        },
        "workingCat.snooze": {
          "type": "boolean",
          "default": false,
          "description": "Play reminder sounds when waiting for permission"
        },
        "workingCat.snoozeInterval": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 300,
          "description": "Snooze interval in seconds (10–300)"
        },
        "workingCat.snoozeCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of snooze reminders (1–10)"
        }
      }
    },
    "views": {
      "working-cat": [
        {
          "type": "webview",
          "id": "workingCat.catView",
          "name": "Cat",
          "icon": "assets/cat.png"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "reinstall": "npm run compile && npm run package && code --install-extension vscode-working-cat-$(node -p \"require('./package.json').version\").vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
